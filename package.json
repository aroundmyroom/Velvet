    "lint:fix": "eslint . --fix",
    "sync-version": "node scripts/sync-webapp-version.cjs",
    "version": "node scripts/sync-webapp-version.cjs && git add -A",
    "test": "node --test test/integration/*.test.cjs test/*.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aroundmyroom/Velvet"
  },
  "author": "AroundMyRoom",
  "homepage": "",
  "license": "GPL-3.0",
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@lvcabral/node-ssdp": "^4.0.4",
    "archiver": "^8.0.0",
    "axios": "^1.17.0",
    "busboy": "^1.6.0",
    "commander": "^15.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "escape-string-regexp": "^5.0.0",
    "essentia.js": "^0.1.3",
    "express": "^5.0.1",
    "fast-xml-parser": "^5.8.0",
    "file-type": "22.0.1",
    "helmet": "^8.2.0",
    "http-proxy": "^1.18.1",
    "joi": "^18.2.1",
