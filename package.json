    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0"
