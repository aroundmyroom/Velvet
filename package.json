{
  "name": "velvet",
  "version": "0.1.1",
  "description": "Velvet — your personal music server",
  "type": "module",
  "main": "cli-boot-wrapper.js",
  "bin": {
    "velvet": "cli-boot-wrapper.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node cli-boot-wrapper.js",
    "wizard": "npm install --only=prod && node cli-boot-wrapper.js",
